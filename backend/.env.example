# Azure AI Foundry — pathfinder-chat project
# Copy this file to .env and fill in your values

AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_KEY=your_azure_key_here
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-oss-120b
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# OpenAI fallback (used for Whisper transcription — Azure not available in australiaeast)
OPENAI_API_KEY=sk-proj-your_key_here
OPENAI_MODEL=gpt-5.5

# Twilio — for SMS + voice calls that bypass silent mode (optional)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+61400000000
# PHONE_BRADLEY=+61411111111
# PHONE_CAMERON=+61422222222
# PHONE_TEYARNEE=+61433333333
